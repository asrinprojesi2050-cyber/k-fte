generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RequestStatus {
  OPEN
  MATCHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum JobStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentMethod {
  CASH
  CARD
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

// Musteri hesaplari
model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  name      String
  email     String?
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requests Request[]
  reviews  Review[]

  @@map("users")
}

// Usta hesaplari
model Provider {
  id                 String             @id @default(uuid())
  phone              String             @unique
  name               String
  bio                String?
  categoryId         String
  category           Category           @relation(fields: [categoryId], references: [id])
  city               String
  latitude           Float?
  longitude          Float?
  photoUrl           String?
  idDocumentUrl      String?
  certificateUrl     String?
  verificationStatus VerificationStatus @default(PENDING)
  ratingAvg          Float              @default(0)
  completedJobsCount Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  offers  Offer[]
  jobs    Job[]
  reviews Review[]

  @@map("providers")
}

// Hizmet kategorileri (oto tamir, ev temizligi, boyaci/tadilat)
model Category {
  id     String @id @default(uuid())
  slug   String @unique
  nameTr String
  nameEn String @default("")
  nameMk String
  nameSq String

  requests  Request[]
  providers Provider[]

  @@map("categories")
}

// Musteri talepleri
model Request {
  id          String        @id @default(uuid())
  customerId  String
  customer    User          @relation(fields: [customerId], references: [id])
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  description String
  budget      Float?
  photoUrls   String[]
  latitude    Float
  longitude   Float
  address     String?
  status      RequestStatus @default(OPEN)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  offers   Offer[]
  job      Job?
  messages Message[]

  @@map("requests")
}

// Usta teklifleri
model Offer {
  id         String      @id @default(uuid())
  requestId  String
  request    Request     @relation(fields: [requestId], references: [id])
  providerId String
  provider   Provider    @relation(fields: [providerId], references: [id])
  price      Float
  message    String?
  status     OfferStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  job Job?

  @@map("offers")
}

// Tamamlanan / surmekte olan isler
model Job {
  id          String    @id @default(uuid())
  requestId   String    @unique
  request     Request   @relation(fields: [requestId], references: [id])
  offerId     String    @unique
  offer       Offer     @relation(fields: [offerId], references: [id])
  providerId  String
  provider    Provider  @relation(fields: [providerId], references: [id])
  status      JobStatus @default(IN_PROGRESS)
  finalPrice  Float
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  review  Review?
  payment Payment?

  @@map("jobs")
}

// Yorumlar ve puanlar
model Review {
  id         String   @id @default(uuid())
  jobId      String   @unique
  job        Job      @relation(fields: [jobId], references: [id])
  customerId String
  customer   User     @relation(fields: [customerId], references: [id])
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@map("reviews")
}

// Mesajlasma
model Message {
  id         String   @id @default(uuid())
  requestId  String
  request    Request  @relation(fields: [requestId], references: [id])
  senderId   String
  senderRole String
  text       String
  createdAt  DateTime @default(now())

  @@index([requestId, createdAt])
  @@map("messages")
}

// Odeme kayitlari (MVP: nakit, platform uzerinden teyit)
model Payment {
  id               String        @id @default(uuid())
  jobId            String        @unique
  job              Job           @relation(fields: [jobId], references: [id])
  amount           Float
  commissionAmount Float
  method           PaymentMethod @default(CASH)
  status           PaymentStatus @default(PENDING)
  confirmedAt      DateTime?
  createdAt        DateTime      @default(now())

  @@map("payments")
}

// Expo push notification tokenlari
model PushToken {
  id        String   @id @default(uuid())
  userId    String
  role      String
  token     String   @unique
  createdAt DateTime @default(now())

  @@index([userId, role])
  @@map("push_tokens")
}
