generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // PROD ortamında 10k kullanıcı için PgBouncer kullanılmalıdır.
  // URL sonuna ?connection_limit=20&pgbouncer=true eklenmelidir.
  url      = env("DATABASE_URL")
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RequestStatus {
  OPEN
  MATCHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum JobStatus {
  WAITING_PAYMENT
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum Currency {
  EUR
  MKD
}

// Musteri hesaplari
model User {
  id               String   @id @default(uuid())
  phone            String   @unique
  name             String
  email            String?
  photoUrl         String?
  isBanned         Boolean  @default(false)
  cancellationCount Int     @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  requests Request[]
  reviews  Review[]

  @@map("users")
}

// Usta hesaplari
model Provider {
  id                 String             @id @default(uuid())
  phone              String             @unique
  name               String
  bio                String?
  categoryId         String
  category           Category           @relation(fields: [categoryId], references: [id])
  city               String
  latitude           Float?
  longitude          Float?
  photoUrl           String?
  idDocumentUrl      String?
  certificateUrl     String?
  verificationStatus VerificationStatus @default(PENDING)
  ratingAvg          Float              @default(0)
  completedJobsCount Int                @default(0)
  isBanned           Boolean            @default(false)
  cancellationCount  Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  offers   Offer[]
  jobs     Job[]
  reviews  Review[]
  targetedRequests Request[] @relation("TargetProvider")

  @@map("providers")
}

// Hizmet kategorileri (oto tamir, ev temizligi, boyaci/tadilat)
model Category {
  id     String @id @default(uuid())
  slug   String @unique
  nameTr String
  nameEn String @default("")
  nameMk String
  nameSq String

  requests  Request[]
  providers Provider[]

  @@map("categories")
}

// Musteri talepleri
model Request {
  id               String        @id @default(uuid())
  customerId       String
  customer         User          @relation(fields: [customerId], references: [id])
  categoryId       String
  category         Category      @relation(fields: [categoryId], references: [id])
  targetProviderId String?
  targetProvider   Provider?     @relation("TargetProvider", fields: [targetProviderId], references: [id])
  description      String
  budget           Float?
  currency         Currency      @default(EUR)
  photoUrls        String[]
  latitude         Float
  longitude        Float
  address          String?
  scheduledAt      DateTime?
  status           RequestStatus @default(OPEN)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  offers   Offer[]
  job      Job?
  messages Message[]

  @@map("requests")
}

// Usta teklifleri
model Offer {
  id         String      @id @default(uuid())
  requestId  String
  request    Request     @relation(fields: [requestId], references: [id])
  providerId String
  provider   Provider    @relation(fields: [providerId], references: [id])
  price      Float
  currency   Currency    @default(EUR)
  message    String?
  isDiscovery Boolean    @default(false)
  status     OfferStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  job Job?

  @@map("offers")
}

// Tamamlanan / surmekte olan isler
model Job {
  id          String    @id @default(uuid())
  requestId   String    @unique
  request     Request   @relation(fields: [requestId], references: [id])
  offerId     String    @unique
  offer       Offer     @relation(fields: [offerId], references: [id])
  providerId  String
  provider    Provider  @relation(fields: [providerId], references: [id])
  status       JobStatus @default(IN_PROGRESS)
  milestone    String?
  finalPrice   Float
  currency     Currency  @default(EUR)
  disputeReason String?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  review  Review?
  payment Payment?
  additionalCosts AdditionalCost[]

  @@map("jobs")
}

// Ekstra Masraflar
model AdditionalCost {
  id          String      @id @default(uuid())
  jobId       String
  job         Job         @relation(fields: [jobId], references: [id])
  amount      Float
  description String
  status      OfferStatus @default(PENDING) // PENDING, ACCEPTED, REJECTED
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("additional_costs")
}

// Yorumlar ve puanlar
model Review {
  id         String   @id @default(uuid())
  jobId      String   @unique
  job        Job      @relation(fields: [jobId], references: [id])
  customerId String
  customer   User     @relation(fields: [customerId], references: [id])
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@map("reviews")
}

// Mesajlasma
model Message {
  id         String   @id @default(uuid())
  requestId  String
  request    Request  @relation(fields: [requestId], references: [id])
  senderId   String
  senderRole String
  text       String
  createdAt  DateTime @default(now())

  @@index([requestId, createdAt])
  @@map("messages")
}

// Odeme kayitlari (MVP: nakit, platform uzerinden teyit)
model Payment {
  id               String        @id @default(uuid())
  jobId            String        @unique
  job              Job           @relation(fields: [jobId], references: [id])
  amount           Float
  commissionAmount Float
  currency         Currency      @default(EUR)
  method           PaymentMethod @default(CASH)
  status           PaymentStatus @default(PENDING)
  confirmedAt      DateTime?
  paidOutAt        DateTime?
  createdAt        DateTime      @default(now())

  @@map("payments")
}

// Expo push notification tokenlari
model PushToken {
  id        String   @id @default(uuid())
  userId    String
  role      String
  token     String   @unique
  createdAt DateTime @default(now())

  @@index([userId, role])
  @@map("push_tokens")
}

// Sistem yoneticileri (Admin)
model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}
